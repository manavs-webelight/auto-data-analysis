WITH region_product_sales AS (
    SELECT 
        vw_sales_orders.customer_region AS region,
        sales_order_items.item_description AS product,
        sales_order_items.material_group AS material_group,
        SUM(sales_order_items.net_value) AS product_revenue,
        SUM(sales_order_items.target_quantity) AS total_qty
    FROM vw_sales_orders
    JOIN sales_order_items 
        ON vw_sales_orders.sales_document = sales_order_items.sales_document
    GROUP BY 
        vw_sales_orders.customer_region,
        sales_order_items.item_description,
        sales_order_items.material_group
),
region_totals AS (
    SELECT 
        region,
        SUM(product_revenue) AS total_region_revenue
    FROM region_product_sales
    GROUP BY region
)
SELECT 
    rps.region,
    rps.product,
    rps.material_group,
    ROUND(rps.product_revenue, 2) AS product_revenue,
    ROUND(rps.total_qty, 0) AS total_quantity,
    ROUND(rt.total_region_revenue, 2) AS total_region_revenue,
    ROUND((rps.product_revenue / rt.total_region_revenue) * 100, 2) AS revenue_percentage
FROM region_product_sales rps
JOIN region_totals rt ON rps.region = rt.region
ORDER BY 
    rps.region,
    revenue_percentage DESC
